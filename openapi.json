  "info": {
    "title": "Lumina API",
    "description": "Web3 semantic localization, glossary, GitOps, and onchain error interpretation API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "https://lumina-e3vi.onrender.com",
      "description": "Production"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateApiKeyDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "production-dapp"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "translate",
                "decode",
                "quote",
                "glossary",
                "metrics",
                "mcp",
                "gitops",
                "admin"
              ]
            }
          },
          "expiresAt": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "scopes"
        ]
      },
      "RotateApiKeyDto": {
        "type": "object",
        "properties": {
          "revokeOld": {
            "type": "object",
            "default": false
          }
        },
        "required": [
          "revokeOld"
        ]
      },
      "TranslateStringDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "example": "Swap {amount} ETH"
          },
          "targetLanguage": {
            "type": "string",
            "example": "pt-BR"
          }
        },
        "required": [
          "text",
          "targetLanguage"
        ]
      },
      "TranslateFileDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "Complete JSON or static TS/JS i18n source"
          },
          "format": {
            "type": "string",
            "enum": [
              "json",
              "ts-i18n",
              "js-i18n"
            ]
          },
          "targetLanguage": {
            "type": "string",
            "example": "fr"
          }
        },
        "required": [
          "content",
          "format",
          "targetLanguage"
        ]
      },
      "GitSyncDto": {
        "type": "object",
        "properties": {}
      },
      "DecodeErrorDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "INSUFFICIENT_OUTPUT_AMOUNT"
          },
          "targetLanguage": {
            "type": "string",
            "example": "zh-CN"
          }
        },
        "required": [
          "code"
        ]
      },
      "LiveQuoteDto": {
        "type": "object",
        "properties": {
          "chainIndex": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "fromTokenAddress": {
            "type": "string"
          },
          "toTokenAddress": {
            "type": "string"
          },
          "swapMode": {
            "type": "string",
            "enum": [
              "exactIn",
              "exactOut"
            ]
          },
          "targetLanguage": {
            "type": "string",
            "example": "fr"
          }
        },
        "required": [
          "chainIndex",
          "amount",
          "fromTokenAddress",
          "toTokenAddress"
        ]
      }
    }
  }
}
