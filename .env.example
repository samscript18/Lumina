# Server
PORT=4000
NODE_ENV=development
DOMAIN=api.your-domain.example
MAX_PAYLOAD_BYTES=1048576
OUTBOUND_REQUEST_TIMEOUT_MS=15000
CORS_ORIGINS=https://your-dapp.example

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lumina

# Redis — provide EITHER a full connection string (REDIS_URL, required for
# TLS providers like Upstash: rediss://default:<token>@host:port) OR the
# discrete host/port/password vars below. REDIS_URL takes priority if set.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
TRANSLATION_CACHE_TTL_SECONDS=2592000

# LLM provider (provider-agnostic: any OpenAI-compatible chat completions endpoint)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
# Alias: GROQ_API_KEY is accepted if LLM_API_KEY is unset (convenience for Groq users)
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# MCP
MCP_HTTP_PORT=3100
MCP_HTTP_ENABLED=true
MCP_ALLOWED_HOSTS=api.your-domain.example

# GitOps webhook
GIT_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_TARGET_LANGUAGES=pt-BR,zh-CN,fr
GITHUB_SOURCE_LOCALE=en
GITHUB_OUTPUT_DIRECTORY=locales

# Required in production. Protects REST, metrics, glossary, and MCP HTTP.
# Send Authorization: Bearer <LUMINA_API_KEY>.
LUMINA_API_KEY=
# Optional comma-separated active keys for zero-downtime rotation. When set,
# this takes precedence over LUMINA_API_KEY.
LUMINA_API_KEYS=

# Scheduled production monitoring (GitHub Actions or an external runner)
LUMINA_BASE_URL=https://lumina-e3vi.onrender.com
ALERT_WEBHOOK_URL=

# Encrypted MongoDB backups to S3-compatible object storage
# Generate BACKUP_ENCRYPTION_KEY with: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=lumina-production
BACKUP_S3_ENDPOINT=
BACKUP_S3_FORCE_PATH_STYLE=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Render API rollback automation (do not set RENDER_ROLLBACK_* persistently)
RENDER_API_KEY=
RENDER_SERVICE_ID=

# OKX OnchainOS credentials (https://web3.okx.com/onchainos/dev-docs/home/developer-portal)
# Required only for the live /onchain/quote endpoint. /decode-error works
# without these using the static, doc-sourced error dictionary.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
