{
  "name": "@lumina-ai/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for Lumina Web3 localization and onchain error intelligence",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samscript18/Lumina.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://samscript.mintlify.app/docs/typescript-sdk",
  "bugs": {
    "url": "https://github.com/samscript18/Lumina/issues"
  },
  "keywords": [
    "web3",
    "localization",
    "typescript",
    "sdk",
    "mcp"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --sourcemap",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
